# ─────────────────────────────────────────────────────────────
# INK SOCIETY — Environment Variables
# Fully serverless: Vercel + Upstash Redis + Groq + Telegram
# ─────────────────────────────────────────────────────────────

# --- Upstash Redis (REST API — serverless friendly) ---
# Get these from the Upstash console -> your database -> "REST API"
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# --- Groq API ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_FALLBACK_MODEL=mixtral-8x7b-32768

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_id
# Secret token that Telegram echoes back on every webhook call.
# Set the same value when registering the webhook (see README).
TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_string

# --- Security ---
# Shared secret required by cron + admin endpoints.
# Send as `Authorization: Bearer <CRON_SECRET>` or `?secret=<CRON_SECRET>`.
CRON_SECRET=generate_a_long_random_string

# --- Tuning ---
IMPORTANCE_THRESHOLD=7
MAX_ARTICLES_PER_RUN=40
AI_BATCH_SIZE=5
SEARCH_SCAN_LIMIT=500
WORDS_PER_MINUTE=200

# Rate limit for /api/search (requests per window, window in seconds)
SEARCH_RATE_LIMIT=30
SEARCH_RATE_WINDOW=60

# Cache TTL (seconds)
CACHE_TTL_SEARCH=300
CACHE_TTL_DEDUP=2592000
